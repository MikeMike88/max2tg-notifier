# -*- coding: utf-8 -*-
"""
Настройки Нотификатора MAX -> Telegram.
Шлём только СИГНАЛ "есть новое сообщение" (без текста), и только по
незамьюченным чатам. Сам текст читаешь в MAX на телефоне.

Скопируй этот файл в config.py и впиши свои значения:
    cp config.py.example config.py       # Linux/macOS
    copy config.py.example config.py     # Windows
config.py добавлен в .gitignore и в репозиторий не попадает.
"""

# --- MAX ---
# Номер телефона аккаунта MAX, например "+79990000000".
# Вводится один раз; при первом запуске MAX пришлёт SMS-код, сессия ляжет в cache/.
MAX_PHONE = "+70000000000"

# --- Telegram ---
# Токен бота от @BotFather (/newbot -> скопировать токен).
TELEGRAM_BOT_TOKEN = "PASTE_YOUR_BOT_TOKEN_HERE"

# Твой chat_id. Узнать: написать боту любое сообщение, затем
#   python get_telegram_chat_id.py
TELEGRAM_CHAT_ID = "PASTE_YOUR_CHAT_ID_HERE"

# --- Анти-спам ---
# Не чаще одного пинга на один и тот же чат за столько секунд.
# (Пришло 10 сообщений подряд в чат садика -> прилетит один сигнал.)
COOLDOWN_SECONDS = 120

# Не слать сигналы по системным событиям чата («X теперь в MAX», «X вышел из
# чата», добавление/удаление участника и т.п.) — это не сообщения.
SKIP_SERVICE_MESSAGES = True

# --- Mute / фильтр чатов ---
# Признак "не беспокоить" MAX отдаёт в персональном user-config внутри LOGIN-
# ответа: config.chats.{chatId}.dontDisturbUntil (-1 = навсегда, 0 = нет, >0 =
# заглушён до момента в мс). main.py читает это при запуске и не шлёт пинги по
# заглушённым чатам. (Раньше думали, что mute не отдаётся, — это было неверно:
# смотрели не туда, в chat.options, где лежат лишь права чата.)
# Поставь False, если хочешь получать сигналы даже из заглушённых чатов.
RESPECT_MAX_MUTE = True

# Жёсткий ручной игнор (страховка): из этих чатов сигналы не шлём никогда.
# chat_id видно в логе уведомлятора.
IGNORED_CHAT_IDS = {
    # 67890,
}

# Если непусто — шлём сигналы ТОЛЬКО из этих чатов (белый список), игнор и mute
# при этом всё равно применяются. Пусто -> следим за всеми незамьюченными.
WATCHED_CHAT_IDS = {
    # 12345,
}

# Человеческие названия чатов: chat_id -> "Название" (для красивого пинга).
# 7212306 — служебный чат MAX (options.SERVICE_CHAT=True): туда приходят коды
# входа и системные уведомления. Имя задаём вручную, т.к. title у него пустой.
CHAT_NAMES = {
    7212306: "Служебный чат MAX",
    # 12345: "Садик",
}
